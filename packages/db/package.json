{
  "name": "@louez/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./env": "./src/env.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "pricing:fix-pricing-mode": "tsx src/scripts/pricing-fix-pricing-mode.ts",
    "pricing:preflight": "tsx src/scripts/pricing-preflight.ts",
    "pricing:backfill": "tsx src/scripts/pricing-backfill.ts",
    "pricing:parity-report": "tsx src/scripts/pricing-parity-report.ts",
    "pricing:parity-top-products": "tsx src/scripts/pricing-parity-top-products.ts",
    "store:clone": "tsx src/scripts/store-clone.ts"
  },
  "dependencies": {
    "@louez/types": "workspace:*",
    "@t3-oss/env-core": "^0.13.10",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "mysql2": "^3.16.0",
    "nanoid": "^5.1.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@louez/config": "workspace:*",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
